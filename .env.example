TARGET_USERNAME=aleabitoreddit

# X API bearer token from the X Developer Platform.
X_BEARER_TOKEN=

# Local working paths inside Cloud Run. These defaults are fine for Cloud Run.
WORK_DIR=/tmp/x_account_monitor
SQLITE_FILENAME=aleabitoreddit.sqlite

# Optional Google Drive sync. Share this folder with the service account email.
GOOGLE_DRIVE_FOLDER_ID=

# Use one of these service account auth methods:
# 1) Preferred for Cloud Run: leave both blank and share the Drive folder
#    with the Cloud Run runtime service account email.
# 2) Alternative: mount Secret Manager as GOOGLE_SERVICE_ACCOUNT_JSON.
GOOGLE_SERVICE_ACCOUNT_JSON=
# 3) Local/dev alternative: path to a service account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=

# Collection behavior.
EXCLUDE_RETWEETS=true
MAX_PAGES=20
